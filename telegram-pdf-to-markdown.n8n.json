          }
        ]
      ]
    },
    "IF: Supported File?": {
      "main": [
        [
          {
            "node": "Telegram: Acknowledge",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Telegram: Unsupported File",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
