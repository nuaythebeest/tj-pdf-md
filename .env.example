# Your Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff...

# Public URL where n8n webhooks are reachable (Telegram needs to call this)
# For local testing: run `ngrok http 5678` and paste the https URL here
WEBHOOK_URL=https://your-domain.com/

# n8n encryption key — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_generate_a_random_32_char_hex

# Timezone for n8n scheduler
GENERIC_TIMEZONE=Asia/Bangkok
